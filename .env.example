# Copy to .env — used by the server (Prisma + Fastify)
DATABASE_URL=postgresql://todo:todo@localhost:5432/todo
# Integration tests use a separate database on the same Postgres instance
DATABASE_URL_TEST=postgresql://todo:todo@localhost:5432/todo_test
PORT=3001
# Session signing key — REQUIRED in production (a dev fallback exists otherwise)
JWT_SECRET=change-me-in-prod
