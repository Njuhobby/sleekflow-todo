generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Declaration order matters: Postgres sorts enum columns by it,
// so ORDER BY priority gives low → medium → high with no mapping.
enum Priority {
  low
  medium
  high
}

enum Status {
  not_started
  in_progress
  completed
  archived
}

/// State machine (R-1.8) — the guard in domain/transitions.ts owns this:
///
///                  ┌──────────────── unarchive ────────────────┐
///                  ▼                                           │
///           not_started ◄────────► in_progress             archived
///               │  ▲                    │                      ▲
///               │  │ reopen             ▼         archive      │
///               │  └─────────────── completed ─────────────────┤
///               │                       ▲  (any non-archived) ─┘
///               └── direct complete ────┘
///
/// Edges INTO in_progress/completed run the blocked guard (R-3.4).
model Todo {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  description String?
  dueDate     DateTime? @map("due_date")
  status      Status    @default(not_started)
  priority    Priority  @default(medium)
  /// Optimistic concurrency token (D4) — doubles as the recurrence-spawn
  /// idempotency guard (D3). Every write is WHERE id = ? AND version = ?.
  version     Int       @default(1)
  /// Soft delete (A5). Deleting also hard-removes dependency edges (R-1.4).
  deletedAt   DateTime? @map("deleted_at")
  /// { frequency: "daily" | "weekly" | "monthly", interval: number } — owned
  /// and validated by domain/recurrence.ts; never filtered on in SQL.
  recurrence  Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  dependencies TodoDependency[] @relation("dependent") // tasks this one waits on
  dependents   TodoDependency[] @relation("dependency") // tasks waiting on this one

  // Every list query filters deletedAt, so composite indexes lead with it (R-6.3)
  @@index([deletedAt, status])
  @@index([deletedAt, priority])
  @@index([deletedAt, dueDate])
  @@index([deletedAt, name])
  @@map("todos")
}

/// Edge "dependentId waits on dependencyId". Rows only ever reference live
/// todos: soft-deleting a todo removes its edges in the same transaction
/// (R-1.4), so blocked computation and cycle detection need no deleted-node
/// special cases (D5).
model TodoDependency {
  dependentId  String @map("dependent_id")
  dependencyId String @map("dependency_id")

  dependent  Todo @relation("dependent", fields: [dependentId], references: [id])
  dependency Todo @relation("dependency", fields: [dependencyId], references: [id])

  @@id([dependentId, dependencyId])
  @@index([dependencyId])
  @@map("todo_dependencies")
}

/// Append-only event log (R-7, D7). Written in the SAME transaction as the
/// mutation it describes, via the single guarded write path — no mutation can
/// skip it. Deliberately no FK to todos: history outlives everything.
model Activity {
  id        String   @id @default(uuid())
  todoId    String   @map("todo_id")
  type      String
  /// Event details; referenced names are snapshotted at event time (R-7.3)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([todoId, createdAt(sort: Desc)])
  @@map("activities")
}
