{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "start": "tsx --env-file=../.env src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=../.env prisma/seed.ts",
    "test:perf": "tsx --env-file=../.env scripts/perf.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.10.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.4.0",
    "fastify-type-provider-zod": "^4.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "prisma": "^6.10.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
