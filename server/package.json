{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "start": "tsx --env-file=../.env src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:seed": "tsx --env-file=../.env prisma/seed.ts",
    "test:perf": "tsx --env-file=../.env scripts/perf.ts",
    "docs:openapi": "NODE_ENV=test tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.10.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "fastify": "^5.4.0",
    "fastify-type-provider-zod": "^4.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.10.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
